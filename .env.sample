# Copy this file to .env and set your values. Do not commit .env.
#   cp .env.sample .env

# -----------------------------------------------------------------------------
# FiftyOne: remote MongoDB (required, shared by the team)
# -----------------------------------------------------------------------------
# Use a remote MongoDB (e.g. Atlas). Same FIFTYONE_DATABASE_URI for everyone so
# the team shares FiftyOne datasets. FiftyOne recommends MongoDB 6.0+.
#
#   FIFTYONE_DATABASE_URI=mongodb+srv://USER:PASSWORD@cluster.xxxxx.mongodb.net/?retryWrites=true&w=majority
#
# With auth: add &authSource=admin (or ?authSource=admin before other params).
#
FIFTYONE_DATABASE_URI=

# If using MongoDB < 6.0, uncomment to bypass compatibility check (may still hit aggregation issues):
# FIFTYONE_DATABASE_VALIDATION=false

# If you see GraphQL/OperationFailure when opening the App, run: fiftyone migrate --all
# (from project root with FIFTYONE_DATABASE_URI set).
#
# Docker + data/processed: put data in data/processed/ddr2019/ (images/, labels.csv).
# Run ./docker/ingest-fiftyone.sh before first "docker compose up" (or when data changes)
# so the Docker App can show images. The App defaults to dataset ddr2019.

# -----------------------------------------------------------------------------
# Optional: Postgres, MinIO (defaults are in docker-compose.yml)
# -----------------------------------------------------------------------------
# Uncomment and set to override. You must also update the corresponding
# service `environment` and `command` in docker-compose.yml to use these.
#
# POSTGRES_USER=mlflow
# POSTGRES_PASSWORD=
# POSTGRES_DB=mlflow
# MINIO_ROOT_USER=minio
# MINIO_ROOT_PASSWORD=
